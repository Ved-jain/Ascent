# ─────────────────────────────────────────────────────────
# Ascent Server Environment Variables
# ─────────────────────────────────────────────────────────

# The port the server runs on (Railway/Render will override this)
PORT=5000

# Environment (development or production)
NODE_ENV=development

# MongoDB Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority

# Secret key used for signing JWT tokens (Make this a long random string in production)
JWT_SECRET=your_jwt_secret_here

# Groq API key for LLM integration
GROQ_API_KEY=your_groq_api_key_here

# Upstash Redis REST configuration
UPSTASH_REDIS_REST_URL="https://great-drum-92371.upstash.io"
UPSTASH_REDIS_REST_TOKEN="gQAAAAAAAWjTAAIgcDJlNDJkZDI3ZWQ3YTQ0NDc5YTliZDI0Njk1NjAzMzM3MQ"

# Allowed origins for CORS (comma separated, no trailing slashes)
# In production, set this to your Vercel URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
